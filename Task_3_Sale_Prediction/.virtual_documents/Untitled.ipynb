import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
import warnings
warnings.filterwarnings("ignore")


df = pd.read_csv("advertising.csv")


df.head()


df.info()


df.describe()


df.shape


df.columns


df.isnull().sum()


df.duplicated().sum()


sns.scatterplot(df,x="TV" , y = "Sales",hue = df['TV'])


sns.scatterplot(df,x="Radio" , y = "Sales",hue = df['Radio'])


sns.scatterplot(df,x="Newspaper" , y = "Sales",hue = df['Newspaper'])


fig = plt.figure(figsize=(8,6))

# 3D axis
ax = fig.add_subplot(111, projection='3d')

# Plot
ax.scatter(df['TV'], df['Radio'], df['Sales'])

# Labels
ax.set_xlabel("TV")
ax.set_ylabel("Radio")
ax.set_zlabel("Sales")

plt.show()



X = df.drop(columns = ["Sales"],axis = True)


y = df["Sales"]


from sklearn.model_selection import train_test_split


X_train,X_test,y_train,y_test = train_test_split(X,y,random_state=42,test_size=0.2)


X_train 


y_train


from sklearn.ensemble import RandomForestRegressor
from sklearn.ensemble import GradientBoostingRegressor
import xgboost as xgb
from sklearn.metrics import r2_score, mean_absolute_error, mean_squared_error


models = {
    "Random Forest": RandomForestRegressor(n_estimators=100, random_state=42),
    "Gradient Boosting": GradientBoostingRegressor(n_estimators=100, random_state=42),
    "XGB Regressor": xgb.XGBRegressor(n_estimators=100, max_depth=3, learning_rate=0.1, random_state=42)
}


results = []


for name, model in models.items():
    model.fit(X_train, y_train)
    y_pred = model.predict(X_test)
    r2 = r2_score(y_test,y_pred)
    results.append({
        'Model': name,
        'r2 Score': round(r2, 4),
    })


results


import joblib
joblib.dump(models['Gradient Boosting'],'GB_model.pkl')
joblib.dump(X.columns.tolist(),'columns.pkl')



