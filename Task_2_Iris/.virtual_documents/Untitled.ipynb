import numpy as np
import pandas as pd
import seaborn as sns
import matplotlib.pyplot as plt
import warnings
warnings.filterwarnings("ignore")





df = pd.read_csv("IRIS.csv")


df.head()


df.tail()


df.info()


df.describe()


df.shape


