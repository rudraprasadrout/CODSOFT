df.isnull().sum()


df.duplicated().sum()


df = df.drop_duplicates()


df.shape





df['species'].value_counts()


df['species'].value_counts().plot(kind = 'bar')





sns.histplot(data=df, x='sepal_length', hue='species', kde=True, element='step')
